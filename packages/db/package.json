{
	"name": "@usetagih/db",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"lint": "biome check .",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"build": "tsc --outDir dist",
		"generate:auth-schema": "bunx auth@1.6.23 generate --config ./src/auth/auth.config.ts --output ./src/schema/better-auth.ts --yes",
		"generate": "drizzle-kit generate",
		"migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@usetagih/config": "workspace:*",
		"better-auth": "1.6.23",
		"drizzle-orm": "0.45.2",
		"postgres": "3.4.9"
	},
	"devDependencies": {
		"auth": "1.6.23",
		"drizzle-kit": "0.31.10",
		"typescript": "^5.8.0"
	}
}
